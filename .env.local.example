# Copy this file to .env.local and fill in your keys.

OPENAI_API_KEY=sk-...

# ElevenLabs API key — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Voice IDs — grab any two from the Voice Library at elevenlabs.io/app/voice-library
# Click a voice → "Copy Voice ID". A = Alex (host 1), B = Jordan (host 2).
ELEVENLABS_VOICE_A=
ELEVENLABS_VOICE_B=
